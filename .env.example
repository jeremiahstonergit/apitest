# Optional runtime settings for the FastAPI control plane.
PORT=8080
SWEB_AUTOMATION_DATA_DIR=.runtime
SWEB_AUTOMATION_MAX_LOGS=50

# SpaceWeb API credentials are intentionally not stored in this repository.
# Normal mode: set login/password; automation scripts call getToken and receive a temporary token.
SWEB_API_LOGIN=
SWEB_API_PASSWORD=

# Optional advanced mode: set only if you obtained a temporary token outside this app.
# SpaceWeb normally returns this token after getToken(login, password); it is not a static secret.
SWEB_API_TOKEN=

# Basic Auth for the control plane web UI. Override these in production.
CONTROL_PLANE_USER=shashkin
CONTROL_PLANE_PASSWORD=dumbilla

# Optional visible deployment marker exposed on /versionz and the UI.
CONTROL_PLANE_REVISION=vps-auth-2026-07-06

# Basic Auth for the control plane web UI. Override these in production.
CONTROL_PLANE_USER=shashkin
CONTROL_PLANE_PASSWORD=dumbilla
